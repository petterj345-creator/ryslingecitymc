# Kopiér til .env.local og udfyld værdierne.

# Supabase — offentlige værdier (Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://din-projekt-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=din-anon-key

# Supabase — service role key (hemmelig, kun server-side)
SUPABASE_SERVICE_ROLE_KEY=din-service-role-key

# Adgangskode til /admin-panelet
ADMIN_PASSWORD=vælg-en-stærk-adgangskode
